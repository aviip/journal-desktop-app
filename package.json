{
  "name": "journal-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main",
  "scripts": {
    "dev": "concurrently -k -n RENDERER,ELECTRON_TSC,ELECTRON -c blue,magenta,green \"npm:dev:renderer\" \"npm:dev:electron:ts\" \"npm:dev:electron:run\"",
    "dev:renderer": "vite --port 5173 --strictPort",
    "dev:electron": "electron .",
    "dev:electron:ts": "tsc -p src/electron/tsconfig.json -w --preserveWatchOutput",
    "dev:electron:run": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 nodemon --watch dist-electron --ext js,mjs,cjs,json --delay 200ms --exec \"electron dist-electron/main.js\"",
    "dev:payments": "node server/index.js",
    "build": "tsc -b && vite build && npm run transpile:electron",
    "lint": "eslint .",
    "preview": "vite preview",
    "transpile:electron": "tsc -p src/electron/tsconfig.json"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.2",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "nodemon": "^3.1.10",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "wait-on": "^8.0.5"
  }
}
